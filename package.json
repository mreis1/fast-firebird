{
  "name": "fast-firebird-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Next-generation Firebird SQL driver ecosystem for Node.js",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "fb:up": "docker compose -p fast-firebird-test -f docker/docker-compose.yml up -d --wait",
    "fb:down": "bash scripts/docker-cleanup.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
